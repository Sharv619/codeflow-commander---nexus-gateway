# Environment Configuration for Codeflow Commander Backend
# Copy this file to .env and update the values

# =================================
# APPLICATION SETTINGS
# =================================
NODE_ENV=development
PORT=5000

# =================================
# DATABASE SETTINGS
# =================================
MONGODB_URI=mongodb://localhost:27017/codeflow
# For production with authentication:
# MONGODB_URI=mongodb://username:password@localhost:27017/codeflow?authSource=admin

# MongoDB Docker defaults (used in docker-compose)
MONGO_ROOT_USERNAME=admin
MONGO_ROOT_PASSWORD=password
MONGO_DATABASE=codeflow

# =================================
# AUTHENTICATION & SECURITY
# =================================
# JWT Secret - CRITICAL: Change this to a secure random string in production!
# Generate with: openssl rand -hex 64
JWT_SECRET=your-super-secret-jwt-key-change-in-production-minimum-32-characters

# JWT Token expiration times
JWT_EXPIRES_IN=24h
REFRESH_TOKEN_EXPIRES_IN=7d

# =================================
# CORS SETTINGS
# =================================
# Frontend URL for CORS (comma-separated for multiple origins)
CORS_ORIGIN=http://localhost:3000

# =================================
# AI SERVICE SETTINGS (for compatibility)
# =================================
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_API_URL=https://generativelanguage.googleapis.com/v1beta/models/gemini-pro:generateContent

# =================================
# RATE LIMITING SETTINGS
# =================================
# Rate limiting window in milliseconds
RATE_LIMIT_WINDOW_MS=900000
# Maximum requests per window
RATE_LIMIT_MAX_REQUESTS=100

# =================================
# LOGGING SETTINGS
# =================================
LOG_LEVEL=info
LOG_FORMAT=json

# =================================
# DEVELOPMENT SETTINGS
# =================================
# Only enable in development
ENABLE_SWAGGER_DOCS=true
ENABLE_CORS_LOGS=false
