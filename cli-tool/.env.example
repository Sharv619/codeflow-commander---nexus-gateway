# CodeFlow Commander CLI Configuration
# Copy this file to .env.local and update with your values
# .env.local is git-ignored and will not be committed

# =================================
# AI PROVIDER SETTINGS
# =================================
# Primary AI provider: gemini, openai, claude, ollama
CODEFLOW_AI_PROVIDER=gemini

# API Key for the selected provider
CODEFLOW_API_KEY=your-api-key-here

# Custom API URL (optional - uses provider default if not set)
CODEFLOW_API_URL=

# Model name (optional - uses provider default if not set)
CODEFLOW_MODEL=

# =================================
# MULTI-PROVIDER SUPPORT
# =================================
# Configure multiple providers for failover/switching
GEMINI_API_KEY=
OPENAI_API_KEY=
CLAUDE_API_KEY=

# =================================
# ENTERPRISE KNOWLEDGE GRAPH
# =================================
# Neo4j connection for Enterprise Knowledge Graph
GRAPH_URL=bolt://localhost:7687
GRAPH_USER=neo4j
GRAPH_PASS=

# =================================
# FEATURE FLAGS
# =================================
# Enable local knowledge store (Phase 3)
ENABLE_KNOWLEDGE_STORE=false

# Enable Enterprise Knowledge Graph (Phase 4)
ENABLE_ENTERPRISE_GRAPH=false

# =================================
# ADVANCED SETTINGS
# =================================
# Verbose logging
CODEFLOW_VERBOSE=false

# Dry run mode (don't make actual changes)
CODEFLOW_DRY_RUN=false

# Cache timeout in milliseconds
CODEFLOW_CACHE_TIMEOUT=3600000

# Maximum retries for API calls
CODEFLOW_MAX_RETRIES=3

# Request timeout in milliseconds
CODEFLOW_TIMEOUT=30000
